# Copy from on-prem-soundbox-backend/.env — same variable names
DATABASE_TYPE=postgres
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SSL_ENABLED=false

# Merchant decryption (GitHub Secrets: ENCRYPTION_KEY, IV)
ENCRYPTION_KEY=
IV=
ENCRYPTION_METHOD=aes-256-cbc

# GCP / Iceberg
GOOGLE_CLOUD_PROJECT=
GCP_REGION=asia-south1
GCS_BUCKET=
WAREHOUSE_PATH=
ICEBERG_NAMESPACE=soundbox

# PyIceberg catalog on Cloud SQL (optional; pandas engine only)
DB_INSTANCE=
ICEBERG_CATALOG_DB_NAME=iceberg_catalog
ICEBERG_CATALOG_DB_USER=
ICEBERG_CATALOG_DB_PASSWORD=

# Ingestion
INGEST_MODE=incremental
INGEST_BATCH_SIZE=5000
UPLOAD_TO_GCS=false
WRITE_LOCAL_PARQUET=true
LAKEHOUSE_LOCAL_ROOT=.tmp/lakehouse
DUCKDB_THREADS=4
WATERMARK_PREFIX=watermarks

# Engine: pandas (< few M rows) | spark (billions — Dataproc Serverless)
INGEST_ENGINE=pandas
SPARK_APP_NAME=soundbox-lakehouse-ingest
SPARK_MASTER=local[*]
SPARK_ICEBERG_CATALOG=lakehouse
SPARK_VERSION=3.5
SPARK_ICEBERG_VERSION=1.5.2
SPARK_JDBC_NUM_PARTITIONS=16
SPARK_JDBC_FETCH_SIZE=10000
SPARK_DECRYPT_PII=false

# API Server security (matches on-prem-soundbox-backend)
AUTH_ENABLED=true
# Production: reject JWT — only X-API-Key from soundbox-backend
AUTH_API_KEY_ONLY=true
AUTH_JWT_SECRET=
LAKEHOUSE_API_KEY=
# Must match LAKEHOUSE_API_KEY in on-prem-soundbox-backend/.env (service-to-service only)
CORS_ENABLED=false
ALLOWED_ORIGINS=
THROTTLE_LIMIT=100
THROTTLE_TTL=60
LOG_LEVEL=INFO
GEMINI_API_KEY=

# SQL / JWT tuning
SQL_MAX_LENGTH=10000
JWT_ALGORITHM=HS256
SERVICE_USER_ID=service
ANONYMOUS_USER_ID=anonymous

# Stateless conversation (backend sends history each request — not stored here)
CONVERSATION_MAX_TURNS=20
CONVERSATION_MAX_MESSAGE_LENGTH=4000
LLM_CONTEXT_WINDOW=6

# Process mode (required — app will not start without this)
# server → Intelligence API (FastAPI)   |   ingest → Postgres → parquet job
RUN_MODE=server
PORT=8080
SERVER_HOST=0.0.0.0
